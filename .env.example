# Copy to .env and fill secrets. Never commit .env.

POSTGRES_DB=supplier_agent_db
POSTGRES_USER=mypes_user
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b

# PDF output inside FastAPI container (host volume: po_pdfs -> /app/generated_pos)
GENERATED_POS_DIR=/app/generated_pos

# LM_STUDIO_MODELS_PATH=  # optional; not required for native Ollama pull

IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

SECRET_KEY=
ENV=development
API_PORT=8000

# ── External catalog search ───────────────────────
EXTERNAL_SEARCH_ENABLED=true
EXTERNAL_SEARCH_DEFAULT_LIMIT=10
EXTERNAL_SEARCH_CACHE_TTL_HOURS=6
EXTERNAL_SEARCH_GLOBAL_TIMEOUT=20

# Optional adapter credentials (CatalogSource.auth overrides these)
AMAZON_PAAPI_ACCESS_KEY=
AMAZON_PAAPI_SECRET_KEY=
AMAZON_PAAPI_PARTNER_TAG=
EBAY_OAUTH_TOKEN=
ALIBABA_APP_KEY=
ALIBABA_APP_SECRET=
